# Coffee Chat Connect — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Core ─────────────────────────────────────────────────────────────────────
# Update this after first Railway deploy to your live URL, e.g.:
# APP_BASE_URL=https://ccc-production.up.railway.app
APP_BASE_URL=http://localhost:5001

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# Set to true for local dev (prints magic links to console, skips email)
DEV_MODE=true

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key_here

# Change to your verified domain once set up in Resend:
# FROM_EMAIL=noreply@coffeechatconnect.com
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=Coffee Chat Connect

# ── APIs ──────────────────────────────────────────────────────────────────────
SERPER_API_KEY=your_serper_api_key_here

# PDL (People Data Labs) — primary lead source with education history
# Get key from: dashboard.peopledatalabs.com → API Keys
# 100 free calls/month; $0.20/call after. Cache per company reduces usage.
PDL_API_KEY=

# Apollo.io People Search — secondary lead source (requires Basic plan $49/mo)
# Get key from: Apollo dashboard → Settings → Integrations → API
APOLLO_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite locally.
# Railway will set this automatically when you add a Postgres plugin.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated. Add your Railway URL here after first deploy:
# ALLOWED_ORIGINS=http://localhost:5001,https://ccc-production.up.railway.app
ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001
