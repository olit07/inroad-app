# Coffee Chat Connect — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Core ─────────────────────────────────────────────────────────────────────
# Update this after first Railway deploy to your live URL, e.g.:
# APP_BASE_URL=https://ccc-production.up.railway.app
APP_BASE_URL=http://localhost:5001

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# Set to true for local dev (prints magic links to console, skips email)
DEV_MODE=true

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_77tPdJQY_3AsZi2N27jrCpeXea8UEeHmf
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_77tPdJQY_3AsZi2N27jrCpeXea8UEeHmf

# Change to your verified domain once set up in Resend:
# FROM_EMAIL=noreply@coffeechatconnect.com
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=Coffee Chat Connect

# ── APIs ──────────────────────────────────────────────────────────────────────
SERPER_API_KEY=7208be0f9b83ce1a3ef0a988b729dd23cae7c4a5

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite locally.
# Railway will set this automatically when you add a Postgres plugin.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated. Add your Railway URL here after first deploy:
# ALLOWED_ORIGINS=http://localhost:5001,https://ccc-production.up.railway.app
ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001
